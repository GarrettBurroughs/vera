// run-pass
func identity<T>(x: T): T {
    return x;
}

struct Point<T> {
    x: T,
    y: T,
}

trait Eq<T> {
    func eq(self: T, other: T): bool;
}

impl<T> Eq<T> for Point<T> {
    func eq(self: Point<T>, other: Point<T>): bool {
        return self.x == other.x;
    }
}

func main(): i32 {
    var p1: Point<i32> = Point { x: 1, y: 2 };
    if identity::<i32>(p1.x) == 1 {
        return 0;
    }
    return 1;
}
