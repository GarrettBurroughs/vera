// verify-fail
// TODO: Update to run-pass/verify-pass once Loop Verification is implemented in WP
func main() {
    var arr: array[i32, 5] = [10, 20, 30, 40, 50];
    var sum: i32 = 0;
    
    for val in arr {
        sum = sum + val;
    }
    
    assert(sum == 150); // wait, verification doesn't support array iteration yet, but at least runtime works
}
