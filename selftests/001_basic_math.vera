// run-pass
// This is a basic self-test to verify arithmetic.

pub func main(): i32 {
    const a = 1;
    const b = 1;
    
    // Assert logic is evaluated
    assert a + b == 2;
    
    if a + b == 2 {
        return 0; // Success exit code
    } else {
        return 1; // Failure exit code
    }
}
