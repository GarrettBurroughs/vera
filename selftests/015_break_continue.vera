// run-pass
// expect-exit-code: 0

pub func main(): i32 {
    var i: i32 = 0;
    var sum: i32 = 0;
    while i < 10 {
        i = i + 1;
        if i == 5 {
            continue;
        }
        sum = sum + i;
        if i == 8 {
            break;
        }
    }
    if sum == 31 {
        return 0;
    } else {
        return 1;
    }
}
